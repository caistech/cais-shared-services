# =============================================================================
# Corporate AI Solutions Portfolio Standard — required env vars
# =============================================================================
# Every product inherits this contract. Replace placeholders before first deploy.
# Never commit the real values. Use Vercel/host env-var UIs (or
# `vercel env pull`) to populate locally.

# --- Supabase (R1, R4, R9 — auth + RLS) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email / Resend (R6) ----------------------------------------------------
# Only `noreply@updates.corporateaisolutions.com` is verified portfolio-wide.
# Custom subdomains require Resend DNS verification first.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@updates.corporateaisolutions.com

# --- Vendor identity (R11 — no hardcoded vendor handles) --------------------
# These power CorporateFooter / vendor lockups when vendor=true. Default state
# is vendor-neutral; only set these if your deployment must show vendor info.
NEXT_PUBLIC_VENDOR_HANDLE=
NEXT_PUBLIC_VENDOR_PHONE=
NEXT_PUBLIC_VENDOR_EMAIL=
NEXT_PUBLIC_VENDOR_CALENDLY=

# --- Portfolio gate (CI smoke + audits) -------------------------------------
# Set PORTFOLIO_GATE_PREVIEW_URL as a GitHub Actions VARIABLE (not secret).
# The CAISTECH_PACKAGES_TOKEN goes in repo Secrets and is mapped to
# GITHUB_PACKAGES_TOKEN inside the workflow (.npmrc reads the env var).
PORTFOLIO_GATE_PREVIEW_URL=
