{
  "name": "@caistech/corporate-components",
  "version": "0.5.2",
  "description": "Corporate AI Solutions React components — theme-able auth surface (AuthForm light/dark + accent, canonical /auth/callback recovery flow), header, footer, explanatory page header (R3), trust scaffolding (R15), ABN lookup, address autocomplete. Plus brand Tailwind palette + global CSS.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "default": "./dist/auth/index.js"
    },
    "./headers": {
      "types": "./dist/headers/index.d.ts",
      "import": "./dist/headers/index.js",
      "default": "./dist/headers/index.js"
    },
    "./trust": {
      "types": "./dist/trust/index.d.ts",
      "import": "./dist/trust/index.js",
      "default": "./dist/trust/index.js"
    },
    "./address-autocomplete": {
      "types": "./dist/address-autocomplete/index.d.ts",
      "import": "./dist/address-autocomplete/index.js",
      "default": "./dist/address-autocomplete/index.js"
    },
    "./tailwind-brand-colors": "./tailwind-brand-colors.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "typescript": ">=5.0.0",
    "@caistech/abn-lookup": "*",
    "@caistech/mapbox": "*",
    "lucide-react": ">=0.300.0"
  },
  "peerDependenciesMeta": {
    "@caistech/abn-lookup": {
      "optional": true
    },
    "@caistech/mapbox": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "lucide-react": ">=0.300.0",
    "@supabase/supabase-js": "^2.0.0",
    "@supabase/ssr": "^0.5.0"
  },
  "files": [
    "dist/",
    "tailwind-brand-colors.js",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/caistech/cais-shared-services.git",
    "directory": "packages/corporate-components"
  },
  "license": "PRIVATE",
  "type": "module"
}
